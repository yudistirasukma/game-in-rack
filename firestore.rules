rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper Primitives
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // User Profile Validation
    function isValidUser(data) {
      return data.keys().hasAll(['userId', 'email', 'createdAt']) &&
             data.userId == request.auth.uid &&
             data.email is string && data.email.size() <= 200 &&
             data.createdAt is string; // format checked by type
    }

    // Game Validation
    function isValidUserGame(data) {
      return data.keys().hasAll(['userId', 'gameId', 'status', 'title']) &&
             data.userId == request.auth.uid &&
             data.title is string && data.title.size() <= 200 &&
             data.status in ['backlog', 'playing', 'completed', 'wishlist'] &&
             (data.get('progress', 0) is number) &&
             (data.get('hoursPlayed', 0) is number);
    }

    // 1. Users Collection
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && 
                    incoming().diff(existing()).affectedKeys().hasAny(['displayName', 'photoURL', 'preferences', 'updatedAt']);
      
      // 2. UserGames Subcollection
      match /games/{gameId} {
        allow list: if isOwner(userId);
        allow get: if isOwner(userId);
        allow create: if isOwner(userId) && isValidUserGame(incoming());
        allow delete: if isOwner(userId);
        allow update: if isOwner(userId) && isValidUserGame(incoming()) && (
          // Action: Update Progress, Priority, Archive status
          incoming().diff(existing()).affectedKeys().hasAny(['progress', 'status', 'updatedAt', 'notes', 'priority', 'isArchived', 'hoursPlayed', 'rating', 'gallery'])
        );
      }
      
      // 3. Wishlist (Optional separate, but I'm doing it within games or separate below if requested)
      match /wishlist/{wishId} {
        allow list: if isOwner(userId);
        allow get: if isOwner(userId);
        allow create: if isOwner(userId);
        allow update, delete: if isOwner(userId);
      }
    }
  }
}
